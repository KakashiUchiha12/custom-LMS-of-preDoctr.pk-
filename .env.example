# preDoctr LMS Environment Variables
# Copy this file to .env and fill in the values

# Database
DB_PASSWORD=predoctr_dev_pass

# JWT - CHANGE THIS IN PRODUCTION to a long random string
JWT_SECRET=change_me_to_a_long_random_secret_in_production

# Server
NODE_ENV=development
PORT=3001

# CORS — React dev server origin
CORS_ORIGIN=http://localhost:5173

# VPS Deployment (fill these in when deploying to DigitalOcean)
# NODE_ENV=production
# CORS_ORIGIN=https://lms.predoctr.pk
